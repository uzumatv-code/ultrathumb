# ─── STORAGE (MinIO / S3-compatible) ──────────────────────────────────────────
# Aliases informativos
MINIO_ENDPOINT=bucketapi.ultrabarber.com.br
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=ss@EP29X35D
MINIO_BUCKET=ultrathumb
MINIO_PUBLIC_URL=https://bucketapi.ultrabarber.com.br

STORAGE_ENDPOINT=bucketapi.ultrabarber.com.br
STORAGE_PORT=443
STORAGE_USE_SSL=true
STORAGE_ACCESS_KEY=admin
STORAGE_SECRET_KEY=ss@EP29X35D
STORAGE_REGION=us-east-1
STORAGE_BUCKET_PRIVATE=ultrathumb-private
STORAGE_BUCKET_PUBLIC=ultrathumb-public
STORAGE_BUCKET_ASSETS=ultrathumb-assets
STORAGE_PUBLIC_URL=https://bucketapi.ultrabarber.com.br/ultrathumb-public

# ─── AI (OpenAI) ──────────────────────────────────────────────────────────────
# Note: In production, these are stored in the database (managed by superadmin)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_ORG_ID=
OPENAI_DEFAULT_MODEL=gpt-image-1
OPENAI_VISION_MODEL=gpt-4o
AI_GENERATION_TIMEOUT_MS=120000
AI_MAX_RETRIES=3

# ─── MERCADO PAGO ─────────────────────────────────────────────────────────────
# Note: In production, these are stored in the database (managed by superadmin)
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...
MP_WEBHOOK_SECRET=your-webhook-secret
MP_NOTIFICATION_URL=https://api.thumbforge.com/webhooks/mercadopago

# ─── EMAIL ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@thumbforge.com
EMAIL_FROM_NAME=ThumbForge AI

# ─── SECURITY ─────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=10
BCRYPT_ROUNDS=12
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# ─── PREVIEW ──────────────────────────────────────────────────────────────────
PREVIEW_WIDTH=480
PREVIEW_HEIGHT=270
PREVIEW_BLUR=2
PREVIEW_WATERMARK_TEXT=THUMBFORGE PREVIEW
PREVIEW_WATERMARK_OPACITY=0.4
PREVIEW_TOKEN_EXPIRES_MINUTES=60
DOWNLOAD_URL_EXPIRES_MINUTES=15

# ─── BUSINESS RULES (defaults — overridable via DB settings) ──────────────────
DEFAULT_PLAN_PRICE_CENTS=4990
DEFAULT_PLAN_GENERATIONS_LIMIT=30
DEFAULT_SINGLE_THUMB_PRICE_CENTS=1990
DEFAULT_COMBO_PRICE_CENTS=4000

# ─── LOGS ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ─── SUPERADMIN (bootstrap only) ──────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@thumbforge.com
SUPERADMIN_PASSWORD=change-me-on-first-login!
