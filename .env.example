# ─── APP ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=ThumbForge AI
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
ADMIN_URL=http://localhost:3001
PORT=4000
WORKER_PORT=4001

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Aliases informativos
DB_HOST=191.252.182.25
DB_PORT=3306
DB_USER=mysql
DB_PASSWORD=628528463e5be7ce135c
