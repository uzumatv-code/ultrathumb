{
  "name": "@thumbforge/backend",
  "version": "1.0.0",
  "private": true,
  "description": "ThumbForge AI — Backend API (Fastify + TypeScript + Prisma)",
  "type": "module",
  "main": "./dist/backend/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/backend/src/server.js",
    "worker:dev": "tsx watch src/workers/index.ts",
    "worker:start": "node dist/backend/src/workers/index.js",
    "db:generate": "node --env-file=../../.env ./node_modules/prisma/build/index.js generate --schema prisma/schema.prisma",
    "db:migrate": "node --env-file=../../.env ./node_modules/prisma/build/index.js migrate deploy --schema prisma/schema.prisma",
    "db:migrate:dev": "node --env-file=../../.env ./node_modules/prisma/build/index.js migrate dev --schema prisma/schema.prisma",
    "db:push": "node --env-file=../../.env ./node_modules/prisma/build/index.js db push --schema prisma/schema.prisma",
    "db:status": "node --env-file=../../.env ./node_modules/prisma/build/index.js migrate status --schema prisma/schema.prisma",
    "db:studio": "node --env-file=../../.env ./node_modules/prisma/build/index.js studio --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@thumbforge/shared": "workspace:*",
    "@prisma/client": "^6.2.1",
    "fastify": "^5.2.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.3",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.2",
    "bullmq": "^5.34.10",
    "ioredis": "^5.4.2",
    "minio": "^8.0.3",
    "sharp": "^0.33.5",
    "openai": "^4.78.1",
    "mercadopago": "^2.5.1",
    "zod": "^3.24.1",
    "bcrypt": "^5.1.1",
    "nodemailer": "^6.9.16",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.5",
    "date-fns": "^4.1.0",
    "socket.io": "^4.8.1",
    "cron": "^3.5.0"
    ,
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.10.7",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
